// Prisma Client yapılandırması
generator client {
  provider = "prisma-client-js"
}

// Veritabanı bağlantı ayarları
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Sistemdeki kullanıcıları temsil eden model
model User {
  id        String   @id @default(cuid())
  name      String
  surname   String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  reviews   Review[]
  addresses Address[]
}

// Ürün kategorilerini temsil eden model (Örn: Ayakkabı, Giyim vs.)
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

// Satışa sunulan ürünleri temsil eden model
model Product {
  id          String      @id @default(cuid())
  name        String
  brand       String
  description String
  price       Float
  imageUrl    String
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  isFeatured  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  reviews     Review[]
  sizes       ProductSize[]
}

// Ürünlerin beden/boyut ve stok bilgilerini tutan model
model ProductSize {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  size      String
  stock     Int     @default(0)

  @@unique([productId, size])
}

// Kullanıcıların ürünler için yaptığı değerlendirmeleri temsil eden model
model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  productId String
  userId    String?
  product   Product  @relation(fields: [productId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// Kullanıcıların verdiği siparişleri temsil eden ana model
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          String      @default("PENDING")
  totalAmount     Float
  shippingName    String
  shippingAddress String
  shippingPhone   String
  paymentMethod   String      @default("CREDIT_CARD_MOCK")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

// Sipariş içerisindeki her bir ürünü temsil eden kalem modeli
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  size      String
}

// Kullanıcıların kayıtlı teslimat ve fatura adreslerini tutan model
model Address {
  id          String   @id @default(cuid())
  title       String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String
  city        String
  district    String
  fullAddress String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
